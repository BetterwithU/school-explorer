{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "$session": {
        ".read": true,
        "gameOn": {
          ".write": true,
          ".validate": "newData.isBoolean()"
        },
        "override": {
          "$team": {
            ".write": true,
            ".validate": "newData.isNumber() || !newData.exists()"
          }
        },
        "teams": {
          "$team": {
            "$device": {
              ".write": true,
              ".validate": "newData.hasChild('step') || !newData.exists()"
            }
          }
        }
      }
    }
  }
}
