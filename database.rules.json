{
  "rules": {
    ".read": "auth != null && auth.token.email.matches(/@snu[.]ms[.]kr$/)",
    ".write": "auth != null && auth.token.email.matches(/@snu[.]ms[.]kr$/)",
    "sessions": {
      "$session": {
        "gameOn": {
          ".validate": "newData.isBoolean()"
        },
        "override": {
          "$team": {
            ".validate": "newData.isNumber() || !newData.exists()"
          }
        },
        "teams": {
          "$team": {
            "$device": {
              ".validate": "newData.hasChild('step') || !newData.exists()"
            }
          }
        }
      }
    }
  }
}
