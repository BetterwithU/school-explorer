{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "B1": {
        ".read": "auth != null && auth.token.email.matches(/@snu[.]ms[.]kr$/)",
        ".write": "auth != null && auth.token.email.matches(/@snu[.]ms[.]kr$/)",
        "gameOn": { ".validate": "newData.isBoolean()" },
        "override": {
          "$team": { ".validate": "newData.isNumber() || !newData.exists()" }
        },
        "teams": {
          "$team": {
            "$device": { ".validate": "newData.hasChild('step') || !newData.exists()" }
          }
        }
      },
      "$session": {
        ".read": true,
        ".write": true
      }
    }
  }
}
